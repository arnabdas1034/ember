{
  "name": "ember",
  "version": "0.1.0",
  "description": "Ember — a Claude-style desktop AI workspace powered by your own Anthropic API key",
  "author": "arnabdas1034",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arnabdas1034/ember.git"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "fetch:model": "node scripts/fetch-model.mjs",
    "predist": "node scripts/fetch-model.mjs",
    "predist:mac": "node scripts/fetch-model.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "highlight.js": "^11.10.0",
    "katex": "^0.16.11",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "zustand": "^5.0.1"
  },
  "build": {
    "appId": "com.ember.desktop",
    "productName": "Ember",
    "publish": [
      {
        "provider": "github",
        "owner": "arnabdas1034",
        "repo": "ember"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/models",
        "to": "models"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "YOUR_GITHUB_USERNAME",
        "repo": "ember"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "resources/icon.icns",
      "identity": null,
      "target": [
        "zip",
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
